# Required only for live LLM runs (AGENTIC_CFO_LLM_MODE=live).
# The default deterministic experiment and the fixture run do not need it.
OPENAI_API_KEY=

# Agentic CFO experiment LLM mode:
#   deterministic (default) -> reproducible, offline stand-ins; no API calls.
#   live                    -> baseline B/C and the agentic system call OpenAI.
AGENTIC_CFO_LLM_MODE=deterministic
AGENTIC_CFO_LLM_MODEL=gpt-4o-mini

# Optional output locations.
PRAXIS_RUNS_DIR=runs
